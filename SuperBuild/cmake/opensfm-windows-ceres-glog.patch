diff --git a/opensfm/src/cmake/win32/FindCeres.cmake b/opensfm/src/cmake/win32/FindCeres.cmake
index 74e2a797..90bdf482 100644
--- a/opensfm/src/cmake/win32/FindCeres.cmake
+++ b/opensfm/src/cmake/win32/FindCeres.cmake
@@ -40,7 +40,25 @@ FIND_LIBRARY(CERES_LIBRARY
   HINTS
     ${_ceres_SEARCH_DIRS}
   PATH_SUFFIXES
-    lib64 lib
+    lib64 lib Library/lib
+  )
+
+FIND_LIBRARY(GLOG_LIBRARY
+  NAMES
+    glog
+  HINTS
+    ${_ceres_SEARCH_DIRS}
+  PATH_SUFFIXES
+    lib64 lib Library/lib
+  )
+
+FIND_LIBRARY(GFLAGS_LIBRARY
+  NAMES
+    gflags
+  HINTS
+    ${_ceres_SEARCH_DIRS}
+  PATH_SUFFIXES
+    lib64 lib Library/lib
   )
 
 # handle the QUIETLY and REQUIRED arguments and set CERES_FOUND to TRUE if
@@ -51,6 +69,12 @@ FIND_PACKAGE_HANDLE_STANDARD_ARGS(ceres DEFAULT_MSG
 
 IF(CERES_FOUND)
   SET(CERES_LIBRARIES ${CERES_LIBRARY})
+  if(GLOG_LIBRARY)
+    list(APPEND CERES_LIBRARIES ${GLOG_LIBRARY})
+  endif()
+  if(GFLAGS_LIBRARY)
+    list(APPEND CERES_LIBRARIES ${GFLAGS_LIBRARY})
+  endif()
   SET(CERES_INCLUDE_DIRS ${CERES_INCLUDE_DIR})
 ENDIF(CERES_FOUND)
 
